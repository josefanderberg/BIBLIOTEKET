@page "/books"
@inject IBookRepository BookRepo

<PageTitle>Böcker</PageTitle>

<h1>📖 Alla böcker</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <input type="text" class="form-control" placeholder="Sök bok (titel, författare eller ISBN)..."
               @bind="searchTerm" @bind:event="oninput" @onkeyup="Search" />
    </div>
    <div class="col-md-6 text-end">
        <button class="btn btn-primary" @onclick="ShowAddForm">+ Lägg till bok</button>
    </div>
</div>

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>Lägg till ny bok</h5>
            <EditForm Model="@newBook" OnValidSubmit="AddBook">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="row">
                    <div class="col-md-3">
                        <label>ISBN</label>
                        <InputText @bind-Value="newBook.ISBN" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label>Titel</label>
                        <InputText @bind-Value="newBook.Title" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label>Författare</label>
                        <InputText @bind-Value="newBook.Author" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label>Utgivningsår</label>
                        <InputNumber @bind-Value="newBook.PublishedYear" class="form-control" />
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-success">Spara</button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (books == null)
{
    <p><em>Laddar böcker...</em></p>
}
else
{
    <p>Visar @books.Count() böcker</p>
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th @onclick='() => SortBy("isbn")' style="cursor:pointer">ISBN ↕</th>
                <th @onclick='() => SortBy("title")' style="cursor:pointer">Titel ↕</th>
                <th @onclick='() => SortBy("author")' style="cursor:pointer">Författare ↕</th>
                <th @onclick='() => SortBy("year")' style="cursor:pointer">År ↕</th>
                <th>Status</th>
                <th>Åtgärd</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in books)
            {
                <tr>
                    <td>@book.ISBN</td>
                    <td><a href="books/@book.Id">@book.Title</a></td>
                    <td>@book.Author</td>
                    <td>@book.PublishedYear</td>
                    <td>
                        @if (book.IsAvailable)
                        {
                            <span class="badge bg-success">🟢 Tillgänglig</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">🔴 Utlånad</span>
                        }
                    </td>
                    <td>
                        <a href="books/@book.Id" class="btn btn-sm btn-outline-primary">Detaljer</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBook(book.Id)">Ta bort</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IEnumerable<Book>? books;
    private string searchTerm = "";
    private bool showForm = false;
    private Book newBook = new();
    private string sortColumn = "title";
    private bool sortAscending = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        books = await BookRepo.GetAllBooksAsync();
        ApplySort();
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadBooks();
        }
        else
        {
            books = await BookRepo.SearchAsync(searchTerm);
        }
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        ApplySort();
    }

    private void ApplySort()
    {
        if (books == null) return;
        books = sortColumn switch
        {
            "isbn" => sortAscending ? books.OrderBy(b => b.ISBN) : books.OrderByDescending(b => b.ISBN),
            "title" => sortAscending ? books.OrderBy(b => b.Title) : books.OrderByDescending(b => b.Title),
            "author" => sortAscending ? books.OrderBy(b => b.Author) : books.OrderByDescending(b => b.Author),
            "year" => sortAscending ? books.OrderBy(b => b.PublishedYear) : books.OrderByDescending(b => b.PublishedYear),
            _ => books
        };
    }

    private void ShowAddForm()
    {
        showForm = !showForm;
        newBook = new Book();
    }

    private async Task AddBook()
    {
        await BookRepo.AddBookAsync(newBook);
        newBook = new Book();
        showForm = false;
        await LoadBooks();
    }

    private async Task DeleteBook(int id)
    {
        await BookRepo.DeleteBookAsync(id);
        await LoadBooks();
    }
}
