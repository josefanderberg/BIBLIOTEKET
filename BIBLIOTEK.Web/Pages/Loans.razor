@page "/loans"
@inject ILoanRepository LoanRepo
@inject IBookRepository BookRepo
@inject IMemberRepository MemberRepo
@using BIBLIOTEK.Core

<PageTitle>Utlåning</PageTitle>

<h1>🔄 Utlåning</h1>

<div class="card mb-3">
    <div class="card-body">
        <h5>Skapa nytt lån</h5>
        <div class="row">
            <div class="col-md-4">
                <label>Välj bok</label>
                <select class="form-select" @bind="selectedBookId">
                    <option value="0">Välj en bok...</option>
                    @foreach (var book in availableBooks)
                    {
                        <option value="@book.Id">@book.Title (@book.ISBN)</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label>Välj medlem</label>
                <select class="form-select" @bind="selectedMemberId">
                    <option value="0">Välj en medlem...</option>
                    @foreach (var member in allMembers)
                    {
                        <option value="@member.Id">@member.Name (@member.MemberId)</option>
                    }
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button class="btn btn-primary" @onclick="CreateLoan">Skapa lån</button>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert alert-info mt-2">@message</div>
        }
    </div>
</div>

<h3>Aktiva lån</h3>
@if (activeLoans == null)
{
    <p><em>Laddar lån...</em></p>
}
else if (!activeLoans.Any())
{
    <p><em>Inga aktiva lån.</em></p>
}
else
{
    @* Mobil-vy *@
    <div class="d-md-none">
        @foreach (var loan in activeLoans)
        {
            <div class="card mb-3 shadow-sm @(loan.IsOverdue ? "border-start border-danger border-4" : "border-start border-info border-4")">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title mb-0">@loan.Book?.Title</h6>
                        @if (loan.IsOverdue)
                        {
                            <span class="badge bg-danger">⚠️ Försenad</span>
                        }
                        else
                        {
                            <span class="badge bg-info">Aktiv</span>
                        }
                    </div>
                    <p class="small mb-1"><strong>Låntagare:</strong> @loan.Member?.Name</p>
                    <p class="small mb-1 text-muted">Lånades: @loan.LoanDate.ToShortDateString()</p>
                    <p class="small mb-3 @(loan.IsOverdue ? "text-danger fw-bold" : "text-muted")">
                        Förfaller: @loan.DueDate.ToShortDateString()
                    </p>
                    <div class="d-grid">
                        <button class="btn btn-warning btn-sm" @onclick="() => ReturnLoan(loan)">Returnera</button>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Skrivbords-vy *@
    <div class="d-none d-md-block">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Bok</th>
                        <th>Låntagare</th>
                        <th>Lånedatum</th>
                        <th>Förfallodatum</th>
                        <th>Status</th>
                        <th>Åtgärd</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loan in activeLoans)
                    {
                        <tr class="@(loan.IsOverdue ? "table-danger" : "")">
                            <td>@loan.Book?.Title</td>
                            <td>@loan.Member?.Name</td>
                            <td>@loan.LoanDate.ToShortDateString()</td>
                            <td>@loan.DueDate.ToShortDateString()</td>
                            <td>
                                @if (loan.IsOverdue)
                                {
                                    <span class="badge bg-danger">⚠️ Försenad</span>
                                }
                                else
                                {
                                    <span class="badge bg-info">Aktiv</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-warning" @onclick="() => ReturnLoan(loan)">Returnera</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private IEnumerable<Loan>? activeLoans;
    private IEnumerable<Book> availableBooks = new List<Book>();
    private IEnumerable<Member> allMembers = new List<Member>();
    private int selectedBookId;
    private int selectedMemberId;
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        activeLoans = await LoanRepo.GetActiveLoansAsync();
        availableBooks = (await BookRepo.GetAllBooksAsync()).Where(b => b.IsAvailable);
        allMembers = await MemberRepo.GetAllMembersAsync();
    }

    private async Task CreateLoan()
    {
        if (selectedBookId == 0 || selectedMemberId == 0)
        {
            message = "Välj både bok och medlem!";
            return;
        }

        var book = await BookRepo.GetByIdAsync(selectedBookId);
        var member = await MemberRepo.GetByIdAsync(selectedMemberId);

        if (book == null || member == null) return;

        var loan = new Loan(book, member, DateTime.Now, DateTime.Now.AddDays(14));
        book.IsAvailable = false;
        
        await LoanRepo.AddLoanAsync(loan);
        await BookRepo.UpdateBookAsync(book);

        message = $"Lån skapat: {book.Title} till {member.Name}";
        selectedBookId = 0;
        selectedMemberId = 0;
        await LoadData();
    }

    private async Task ReturnLoan(Loan loan)
    {
        loan.ReturnDate = DateTime.Now;
        if (loan.Book != null)
        {
            loan.Book.IsAvailable = true;
            await BookRepo.UpdateBookAsync(loan.Book);
        }
        await LoanRepo.UpdateLoanAsync(loan);
        message = $"Returnerat: {loan.Book?.Title}";
        await LoadData();
    }
}
