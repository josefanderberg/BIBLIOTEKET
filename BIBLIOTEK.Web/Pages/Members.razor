@page "/members"
@inject IMemberRepository MemberRepo
@using BIBLIOTEK.Core

<PageTitle>Medlemmar</PageTitle>

<h1>👥 Medlemmar</h1>

<div class="row mb-3">
    <div class="col-md-6"></div>
    <div class="col-md-6 text-end">
        <button class="btn btn-primary" @onclick="ShowAddForm">+ Registrera ny medlem</button>
    </div>
</div>

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>Registrera ny medlem</h5>
            <EditForm Model="@newMember" OnValidSubmit="AddMember">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="row">
                    <div class="col-md-3">
                        <label>Medlems-ID</label>
                        <InputText @bind-Value="newMember.MemberId" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label>Namn</label>
                        <InputText @bind-Value="newMember.Name" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label>E-post</label>
                        <InputText @bind-Value="newMember.Email" class="form-control" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-success">Spara</button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (members == null)
{
    <p><em>Laddar medlemmar...</em></p>
}
else
{
    @* Mobil-vy *@
    <div class="d-md-none">
        @foreach (var member in members)
        {
            <div class="card mb-3 shadow-sm border-start border-primary border-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title mb-0">@member.Name</h5>
                        <span class="badge bg-info">@member.Loans.Count(l => l.ReturnDate == null) lån</span>
                    </div>
                    <p class="card-subtitle mb-2 text-muted">@member.Email</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-secondary">Medlem sedan: @member.MemberSince.ToShortDateString()</small>
                        <a href="members/@member.Id" class="btn btn-primary btn-sm">Detaljer</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Skrivbords-vy *@
    <div class="d-none d-md-block">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Medlems-ID</th>
                        <th>Namn</th>
                        <th>E-post</th>
                        <th>Medlem sedan</th>
                        <th>Aktiva lån</th>
                        <th>Åtgärd</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in members)
                    {
                        <tr>
                            <td>@member.MemberId</td>
                            <td>@member.Name</td>
                            <td>@member.Email</td>
                            <td>@member.MemberSince.ToShortDateString()</td>
                            <td>
                                <span class="badge bg-info">
                                    @member.Loans.Count(l => l.ReturnDate == null)
                                </span>
                            </td>
                            <td>
                                <a href="members/@member.Id" class="btn btn-sm btn-outline-primary">Detaljer</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private IEnumerable<Member>? members;
    private bool showForm = false;
    private Member newMember = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMembers();
    }

    private async Task LoadMembers()
    {
        members = await MemberRepo.GetAllMembersAsync();
    }

    private void ShowAddForm()
    {
        showForm = !showForm;
        newMember = new Member();
    }

    private async Task AddMember()
    {
        newMember.MemberSince = DateTime.Now;
        await MemberRepo.AddMemberAsync(newMember);
        newMember = new Member();
        showForm = false;
        await LoadMembers();
    }
}
